# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# OLLAMA_API_URL: The public URL to your local Ollama instance (e.g., via ngrok)
# Example: https://1234-abcd.ngrok.io
OLLAMA_API_URL=""

# OLLAMA_MODEL: The vision model to use with Ollama (default: llava)
# Example: llava, llama3.2-vision
OLLAMA_MODEL=""

# NVIDIA API Key for AI capabilities
NVIDIA_API_KEY=""

# Supabase configuration for tracking scraped metadata
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Gemini API configuration
GEMINI_API_KEY=""
