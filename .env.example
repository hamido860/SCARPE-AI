# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# OLLAMA_API_URL: The public URL to your local Ollama instance (e.g., via ngrok)
# Example: https://1234-abcd.ngrok.io
OLLAMA_API_URL=""

# OLLAMA_MODEL: The vision model to use with Ollama (default: llava)
# Example: llava, llama3.2-vision
OLLAMA_MODEL=""

# NVIDIA API Key for AI capabilities
NVIDIA_API_KEY=""

# Supabase configuration for tracking scraped metadata
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Gemini API configuration
GEMINI_API_KEY=""

# OCR Queue Settings
MISTRAL_API_KEY=""
OCR_CONCURRENCY=1
OCR_DELAY_BETWEEN_PAGES_MS=8000
OCR_DELAY_BETWEEN_PDFS_MS=30000
OCR_MAX_PAGES_PER_PDF=30
OCR_MAX_PDFS_PER_BATCH=5
OCR_MAX_RETRIES=3
OCR_BACKOFF_MULTIPLIER=2
OCR_DAILY_PAGE_LIMIT=100

